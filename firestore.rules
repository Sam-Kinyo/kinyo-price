rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /Products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ProductImages/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /SiteConfig/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ProductClicks/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
    }
    match /SyncMetadata/{docId} {
      allow read, write: if request.auth != null;
    }
    match /Customers/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null;
    }
    match /CustomerOrders/{orderId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
    }
    // AdminQuestions / AdminReplyState：僅由 Cloud Functions (admin SDK) 存取，前端不可直接讀寫
    match /AdminQuestions/{questionId} {
      allow read, write: if false;
    }
    match /AdminReplyState/{uid} {
      allow read, write: if false;
    }
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
