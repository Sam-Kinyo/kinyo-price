                returnDate: { type: Type.STRING, description: "預計歸還日期", nullable: true }
            },
            required: ["company", "name", "phone", "address", "deliveryTime", "remark", "projectName", "returnDate"]
        },
        orderItems: {
            type: Type.ARRAY,
            description: "下單商品清單陣列 (僅在 intent 為 'order' 時輸出)",
            nullable: true,
            items: {
                type: Type.OBJECT,
                properties: {
